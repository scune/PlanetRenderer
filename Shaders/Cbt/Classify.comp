layout(local_size_x = 64) in;

layout(binding = 0) readonly buffer Cbt
{
  uint tree[CBT_TREE_SIZE];
  uint64_t bitfield[CBT_BITFIELD_SIZE];
} cbt;

layout(binding = 1) readonly buffer PointerCache
{
  uint activeBisectors[BISECTOR_MAX_COUNT];
};

layout(binding = 2, scalar) buffer Bisectors
{
  Bisector bisectors[BISECTOR_MAX_COUNT];
};

layout(binding = 7, scalar) readonly buffer OutVertices
{
  layout(offset = 20)
  PlanetVertex cachedVertices[3 * BISECTOR_MAX_COUNT];
};

layout(binding = 6) writeonly buffer BisectorCommands
{
  uint bisectorCommands[BISECTOR_MAX_COUNT];
};

layout(binding = 8) uniform GlobalUpdate
{
  mat4 camMatrix;
  vec4 frustumPlanes[4];
  vec4 camPos;
  vec4 lookAt;
};

layout(binding = 9) buffer DebugBuffer
{
  ivec2 debugData[];
};

layout(binding = 12) readonly buffer VertexIndices
{
  uint vertexIndices[];
}

layout(push_constant, scalar) uniform PushConstant
{
  layout(offset = 4)
  uint maxSubdivision;
  uint minDepth;
  uint baseBisectorIndex;
  uint pixelCount;
};



bool FrustumCullPoint(vec3 p)
{
  for (uint i = 0; i < 4; i++)
  {
    if (dot(frustumPlanes[i], vec4(p, 1.f)) < 0.f)
      return true;
  }
  return false;
}

