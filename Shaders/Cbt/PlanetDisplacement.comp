{
  const uint parentCount = (vertexCount + 2) / 3;
  if (gl_GlobalInvocationID.x >= vertexCount + parentCount)
    return;

  const bool bParent = ((gl_GlobalInvocationID.x % 4) == 3);
  const uint vIdx = gl_GlobalInvocationID.x - gl_GlobalInvocationID.x / 4;

  vec3 v;
  if (bParent)
  {
    [[unroll]]
    for (uint i = 0; i < 3; i++)
      v[i] = outVertices[vIdx - 3 + i].pos.w;
    // TODO: Get from subgroup op's
  }
  else
  {
    v = outVertices[vIdx].pos.xyz;
  }

  /*const vec3 absV = abs(v);
  if (absV.x > absV.y && absV.x > absV.z)
    v /= absV.x;
  else if (absV.y > absV.z)
    v /= absV.y;
  else
    v /= v.z;

  v *= 10000.f;

  vec4 normal = vec4(v, 1.f);*/

  uint planeID;
  uint extent3;
  vec3 cubeWorldPos;
  vec2 uv = CubeProj(v, planeID, extent3, cubeWorldPos);

  vec3 ad = Terrain(uv, cubeWorldPos, planeID, extent3);
  ad.x *= fbmAmplitude;

  vec4 normal;
  normal.xyz = AlignToNormal(ad.yz * amplitudePercent, v, planeID);
  //normal.xyz = cubeWorldPos;
  //normal.xyz = SubgroupNormal(v);
  normal.w = ad.x;

  v *= ad.x + planetScale;

  //v += normalize(v) * 3.5f * TerrainTextDisplace(v, normal.xyz);

  uint delta = 3u - gl_SubgroupInvocationID % 4;
  float parent = subgroupShuffleDown(v, delta)[vIdx % 3];
  if (bParent)
    return;

  outVertices[vIdx].pos = vec4(v, parent);
  outVertices[vIdx].normal = normal;

  /*if (bParent)
  {
    [[unroll]]
    for (uint i = 0; i < 3; i++)
      outVertices[vIdx - 3 + i].pos.w = v[i];
  }
  else
  {
    outVertices[vIdx].pos.xyz = v;
    outVertices[vIdx].normal = normal;
  }*/
}
