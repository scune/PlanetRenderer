// Accepts a signed normalized pos
// Returns UV in interval [0.f, 1.f]
// and ID of the plane from the cube
vec2 CubeProj(const vec3 pos, out uint planeID, out uint offset3, out vec3 cubeWorldPos)
{
  const vec3 absP = abs(pos);
  vec3 uv = pos;

  if (absP.x > absP.y && absP.x > absP.z) // x
  {
    bool positive = (uv.x > 0.f);
    planeID = (positive) ? 0 : 2;
    offset3 = 418;
    //uv.y *= (positive) ? 1.f : -1.f;
    //uv.xy = uv.yz / absP.x;
    uv.xy = uv.yz / absP.x;
    cubeWorldPos = pos / absP.x;
  }
  else if (absP.y > absP.z) // y
  {
    bool positive = (uv.y > 0.f);
    planeID = (positive) ? 1 : 3;
    offset3 = 353;
    //uv.x *= (positive) ? -1.f : 1.f;
    //uv.xy = uv.xz / absP.y;
    uv.xy = uv.xz / absP.y;
    cubeWorldPos = pos / absP.y;
  }
  else // z
  {
    bool positive = (uv.z > 0.f);
    planeID = (positive) ? 4 : 5;
    offset3 = 209;
    //uv.x *= (positive) ? -1.f : 1.f;
    //uv.xy = uv.yx / absP.z;
    uv.xy /= absP.z;
    cubeWorldPos = pos / absP.z;
  }
  cubeWorldPos = cubeWorldPos * 0.5f + 0.5f;
  return uv.xy * 0.5f + 0.5f;
}

uvec2 Pcg2D(uvec2 v)
{
  v = v * 1664525u + 1013904223u;
  v.x += v.y * 1664525u;
  v.y += v.x * 1664525u;
  v = v ^ (v >> 16u);
  v.x += v.y * 1664525u;
  v.y += v.x * 1664525u;
  v = v ^ (v >> 16u);
  return v;
}

vec2 Uvec2ToUnitVec2(const uvec2 u)
{
  return (u >> 8u) * 5.9604644775390625e-08f;
}

vec2 Hash2D(uvec2 u/*, uint planeID */)
{/*
  if (u.y == 0)
  {
    if (planeID == 1)
    {
      debugData[u.x] = ivec2(u);
      return vec2(u.x) / 10.f;
    }
    else if (planeID == 5)
    {
      debugData[u.x + 10] = ivec2(u);
      return vec2(u.x) / 10.f;
    }
  }*/
  u = Pcg2D(u);
  return Uvec2ToUnitVec2(u) * 2.f - 1.f;
}

uvec3 Pcg3d(uvec3 v)
{
  v = v * 1664525u + 1013904223u;
  v.x += v.y * v.z;
  v.y += v.z * v.x;
  v.z += v.x * v.y;
  v ^= v >> 16u;
  v.x += v.y * v.z;
  v.y += v.z * v.x;
  v.z += v.x * v.y;
  return v;
}

vec3 Hash3D(uvec3 i, const uvec3 extent)
{
  return (Pcg3d(i) >> 8u) * 5.9604644775390625e-08 * 2.f - 1.f;
}

uvec3 Extract(const uint extent3, const int offset)
{
  return uvec3(bitfieldExtract(extent3, offset + 0, 1),
               bitfieldExtract(extent3, offset + 1, 1),
               bitfieldExtract(extent3, offset + 2, 1));
}

uvec3 Extract1(const uint extent3) { return Extract(extent3, 0); }
uvec3 Extract2(const uint extent3) { return Extract(extent3, 3); }
uvec3 Extract3(const uint extent3) { return Extract(extent3, 6); }

// Accepts an unsigned vec2
vec3 PerlinNoise2D(const vec2 x, const uvec3 cubePos, const uvec3 extent, const uint extent3, const uint planeID)
{
  uvec2 xu = uvec2(x);

  vec2 ga = Hash2D(xu + uvec2(0, 0));
  vec2 gb = Hash2D(xu + uvec2(1, 0));
  vec2 gc = Hash2D(xu + uvec2(0, 1));
  vec2 gd = Hash2D(xu + uvec2(1, 1));

  vec2 f = fract(x);

  float va = dot(ga, f - vec2(0.f, 0.f));
  float vb = dot(gb, f - vec2(1.f, 0.f));
  float vc = dot(gc, f - vec2(0.f, 1.f));
  float vd = dot(gd, f - vec2(1.f, 1.f));

  if (xu.x == extent.x) // Min x
  {
    vec3 ga3 = Hash3D(cubePos, extent);
    vec3 gc3 = Hash3D(cubePos + Extract2(extent3), extent);
    ga3.xy *= ga3.z;
    gc3.xy *= gc3.z;

    va = dot(ga3.xy, f - vec2(0.f, 0.f));
    vc = dot(gc3.xy, f - vec2(0.f, 1.f));
  }
  else if (xu.x == extent.y - 1) // Max x
  {
    vec3 gb3 = Hash3D(cubePos + Extract1(extent3), extent);
    //vec3 gb3 = vec3(cubePos.xx + 1, 1.f);
    //vec3 gb3 = vec3(0.6f, -0.2f, 1.f);
    vec3 gd3 = Hash3D(cubePos + Extract3(extent3), extent);
    //vec3 gd3 = vec3(cubePos.zz, 1.f);
    //vec3 gd3 = vec3(0.4f, 0.6f, 1.f);
    //vec3 gd3 = vec3(1.f);
    //gb3.xy *= gb3.z;
    //gd3.xy *= gd3.z;

    vb = dot(gb3.xy, f - vec2(1.f, 0.f));
    vd = dot(gd3.xy, f - vec2(1.f, 1.f));
  }
  if (xu.y == 0) // Min y
  {
    vec3 ga3 = Hash3D(cubePos, extent);
    vec3 gb3 = Hash3D(cubePos + Extract1(extent3), extent);
    ga3.xy *= ga3.z;
    gb3.xy *= gb3.z;

    va = dot(ga3.xy, f - vec2(0.f, 0.f));
    vb = dot(gb3.xy, f - vec2(1.f, 0.f));
  }
  else if (xu.y == extent.z - 1) // Max y
  {
    vec3 gc3 = Hash3D(cubePos + Extract2(extent3), extent);
    //vec3 gc3 = vec3(cubePos.xx, 1.f);
    //vec3 gc3 = vec3(0.6f, -0.2f, 1.f);
    vec3 gd3 = Hash3D(cubePos + Extract3(extent3), extent);
    //vec3 gd3 = vec3(cubePos.zz + 1, 1.f);
    //vec3 gd3 = vec3(0.4f, 0.6f, 1.f);
    //gc3.xy *= gc3.z;
    //gd3.xy *= gd3.z;

    if (planeID == 0) // TODO: Fix without this/Understand why
    {
      gc3.xy = gc3.yx;
      gd3.xy = gd3.yx;
    }

    vc = dot(gc3.xy, f - vec2(0.f, 1.f));
    vd = dot(gd3.xy, f - vec2(1.f, 1.f));
  }

  vec2 u = f * f * f * (f * (f * 6.f - 15.f) + 10.f);
  vec2 du = 30.f * f * f * (f * (f - 2.f) + 1.f);

  return vec3(va + u.x*(vb-va) + u.y*(vc-va) + u.x*u.y*(va-vb-vc+vd),  // Value
              ga + u.x*(gb-ga) + u.y*(gc-ga) + u.x*u.y*(ga-gb-gc+gd) + // Derivative
              du * (u.yx*(va-vb-vc+vd) + vec2(vb,vc) - va));
}

vec3 Terrain(vec2 p, vec3 cubePosF, const uint planeID, const uint extent3)
{
  const mat2 m = mat2(0.8f, -0.6f,
                      0.6f,  0.8f);

  p.x += planeID; // ]planeID, planeID + 1[
  p *= float(fbmFrequency); // ]planeID * fbmFrequency, (planeID + 1) * fbmFrequency[
  uvec3 extent = uvec3(planeID * fbmFrequency, (planeID + 1) * fbmFrequency, fbmFrequency); // .x = x_min, .y = x_max, .z = y_max
  //uvec3 extent = uvec3(0, fbmFrequency, fbmFrequency); // .x = x_min, .y = x_max, .z = y_max

  vec3 an = vec3(0.f); // .x = height, .yz = derivate
  float b = 1.f;
  vec2 d = vec2(0.f);
  vec3 cubePos = vec3(cubePosF * fbmFrequency);
  for (int i = 0; i < 10; i++)
  {
    vec3 n = PerlinNoise2D(p, uvec3(cubePos), extent, extent3, planeID);

    //float erosion = 1.f + dot(d, d);
    float erosion = 1.f;
    an.yz += n.yz / erosion;

    d += n.yz;

    //float erosion2 = 1.f + dot(d, d);
    float erosion2 = 1.f;
    an.x += b * n.x / erosion2;

    b *= 0.5f;
    //p = m * p * 2.f; // TODO: Maybe fix?
    p *= 2.f;
    extent <<= 1;
    cubePos *= 2.f;
  }
  an.yz *= float(fbmFrequency);
  return an;
}

vec2 Rotate(vec2 v, float angle)
{
  float s = sin(angle);
  float c = cos(angle);
  return vec2(v.x * c - v.y * s, v.x * s + v.y * c);
}

void RotateMsc(inout vec3 worldPos, float offset, const vec3 normal)
{
  float blendSharpness = 10.f;

  vec3 blending = abs(normal);
  blending = pow(blending, vec3(blendSharpness));

  float rotation = 60.f * (offset + 0.5f);
  if (blending.x > blending.y && blending.x > blending.z)
  {
    worldPos.yz = Rotate(worldPos.yz, rotation);
  }
  else if (blending.y > blending.z)
  {
    worldPos.xz = Rotate(worldPos.xz, rotation);
  }
  else
  {
    worldPos.xy = Rotate(worldPos.xy, rotation);
  }
}

vec3 TriplanarProjection(uint textureID, vec3 worldPos, const vec3 normal)
{
  float blendSharpness = 10.f;

  vec3 blending = abs(normal);
  blending = pow(blending, vec3(blendSharpness));

  float weightSum = blending.x + blending.y + blending.z;
  blending /= weightSum;

  vec3 color[3];
  color[0] = texture(Textures[textureID], worldPos.yz).rgb;
  color[1] = texture(Textures[textureID], worldPos.xz).rgb;
  color[2] = texture(Textures[textureID], worldPos.xy).rgb;

  return color[0] * blending.x + color[1] * blending.y + color[2] * blending.z;
}

float MinComp(vec2 v)
{
  return min(v.x, v.y);
}

float GridBoundingDist(vec3 gridPos, vec3 normal)
{
  vec3 absN = abs(normal);
  if (absN.x > absN.y && absN.x > absN.z)
  {
    gridPos.xy = gridPos.yz;
  }
  else if (absN.y > absN.z)
  {
    gridPos.xy = gridPos.xz;
  }
  gridPos.xy = fract(abs(gridPos.xy));
  float minDist = MinComp(gridPos.xy);
  minDist = min(minDist, MinComp(vec2(1.f) - gridPos.xy));
  return minDist;
}

vec3 TerrainColorWithOffset(vec3 offsetWorldPos, const vec3 normal, float scaling2, float textBlendAlpha)
{
  float rockAlpha = textBlendAlpha;

  vec3 color = vec3(0.f);
  if (rockAlpha > 0.f)
  {
    color += TriplanarProjection(1, offsetWorldPos / scaling2, normal) * rockAlpha;
  }
  if (rockAlpha < 1.f)
  {
    color += TriplanarProjection(3, offsetWorldPos, normal) * (1.f - rockAlpha);
  }
  return color;
}

vec3 Hash3D(uvec3 u)
{
  return (Pcg3d(u) >> 8u) * 5.9604644775390625e-08;
}

float TerrainTextDisplace(const vec3 pos, const vec3 normal)
{
  const float slopeRockCutoff = 0.6f;
  const float slopeRockBlendCutoff = 0.65f;

  float slope = dot(normalize(pos), normal);
  bool rock = (slope < slopeRockCutoff);
  bool textBlend = (!rock && slope < slopeRockBlendCutoff);
  float textBlendAlpha = (rock) ? 1.f : 0.f;
  if (textBlend)
  {
    textBlendAlpha = 1.f - min(1.f, (slope - slopeRockCutoff)) / (slopeRockBlendCutoff - slopeRockCutoff);
  }

  vec3 gridPos = pos.xyz / 150.f;
  vec3 offset = Hash3D(uvec3(gridPos + 200.f));
  float gridBoundDist = GridBoundingDist(gridPos, normal);

  float scaling = 10.f;
  float scaling2 = 2.f;
  vec3 worldPos = pos.xyz / scaling;

  vec3 offsetWorldPos = worldPos;
  RotateMsc(offsetWorldPos, offset.x, normal);
  offsetWorldPos *= 0.6f * (offset.y + 0.5f);
  offsetWorldPos += 0.7f * (offset.z + 0.5f);

  float displace = TerrainColorWithOffset(offsetWorldPos, normal, scaling2, textBlendAlpha).x;

  float defaultCutoff = 0.2f;
  if (gridBoundDist > defaultCutoff)
    return displace;

  vec3 offsetWorldPos2 = worldPos * 0.5f + 0.5f; // Offset by 0.5 so the cell edges are in the other cells

  float defaultDisplaceAlpha = 1.f - (gridBoundDist / defaultCutoff);
  float defaultDisplace = TerrainColorWithOffset(offsetWorldPos2, normal, scaling2, textBlendAlpha).x;
  return mix(displace, defaultDisplace, defaultDisplaceAlpha);
}

vec3 SubgroupNormal(vec3 v)
{
  uint baseVertex = gl_SubgroupInvocationID & (~3u);
  vec3 v0 = subgroupShuffle(v, baseVertex);
  vec3 v1 = subgroupShuffle(v, baseVertex + 1);
  vec3 v2 = subgroupShuffle(v, baseVertex + 2);
  return normalize(cross(v1 - v0, v2 - v0));
}

vec3 ProjectOrthogonal(vec3 dir, vec3 proj)
{
  return dir - dot(dir, proj) * proj;
}

vec3 AlignToNormal(const vec2 dir, const vec3 normal, const uint planeID)
{
  vec3 tangent;
  vec3 bitangent;
  if (planeID == 0)
  {
    tangent = ProjectOrthogonal(vec3(0.f, 1.f, 0.f), normal);
    bitangent = ProjectOrthogonal(vec3(0.f, 0.f, 1.f), normal);
  }
  else if (planeID == 1)
  {
    tangent = ProjectOrthogonal(vec3(-1.f, 0.f, 0.f), normal);
    bitangent = ProjectOrthogonal(vec3(0.f, 0.f, 1.f), normal);
  }
  else if (planeID == 2)
  {
    tangent = ProjectOrthogonal(vec3(0.f, -1.f, 0.f), normal);
    bitangent = ProjectOrthogonal(vec3(0.f, 0.f, 1.f), normal);
  }
  else if (planeID == 3)
  {
    tangent = ProjectOrthogonal(vec3(1.f, 0.f, 0.f), normal);
    bitangent = ProjectOrthogonal(vec3(0.f, 0.f, 1.f), normal);
  }
  else if (planeID == 4)
  {
    tangent = ProjectOrthogonal(vec3(0.f, 1.f, 0.f), normal);
    bitangent = ProjectOrthogonal(vec3(-1.f, 0.f, 0.f), normal);
  }
  else if (planeID == 5)
  {
    tangent = ProjectOrthogonal(vec3(0.f, 1.f, 0.f), normal);
    bitangent = ProjectOrthogonal(vec3(1.f, 0.f, 0.f), normal);
  }

  vec3 gradient = dir.x * tangent + dir.y * bitangent;
  return normalize(normal - gradient);
}

